{
  "name": "fund-quant-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @fund-quant/api",
    "dev:web": "npm run dev --workspace @fund-quant/web",
    "build": "npm run build --workspace @fund-quant/api && npm run build --workspace @fund-quant/web",
    "start": "node apps/api/dist/server.js",
    "test": "npm run test --workspace @fund-quant/api"
  }
}